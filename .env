NEXT_TELEMETRY_DISABLED=1

# External Entity API base URL.
# In development, points at the local mock routes in the same Next.js process.
# Downstream projects set this to their real API domain (e.g. https://myservice.example.com/api).
ENTITY_API_BASE=http://localhost:3000/api/mock
OPENAI_API_KEY="NOT USED.  This is needed to run web based mongodb client for development use"

# MongoDB Configuration
MONGODB_USER=root
MONGODB_PASSWORD=password
MONGODB_HOST=localhost
MONGODB_DATABASE=ride
MONGODB_PORT=27017